{
  "declarative_only": true,
  "no_24x7": true,
  "alerts": [
    {
      "id": "audit-heartbeat-stale",
      "title": "Audit heartbeat stale",
      "signal": {
        "source": "pipedrive.audit",
        "category": "export",
        "operation": "audit.export.heartbeat",
        "measurement": "freshness_seconds"
      },
      "window": "15m",
      "comparator": ">",
      "threshold": 900,
      "severity": "critical",
      "owner": "Alexandre",
      "backup": "D08_pending",
      "route": "email_placeholder",
      "freeze_action": "freeze_destructive_changes",
      "ack_target": "best_effort_no_24x7",
      "runbook": "docs/INCIDENT_RESPONSE.md",
      "evidence_fields": [
        "eventId",
        "ts",
        "environment",
        "worker",
        "versionId",
        "operation",
        "outcome"
      ],
      "live_status": "not_configured"
    },
    {
