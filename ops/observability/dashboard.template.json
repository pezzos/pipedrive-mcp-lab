{
  "declarative_only": true,
  "no_24x7": true,
  "panels": [
    {
      "id": "heartbeat-freshness",
      "title": "Heartbeat freshness",
      "source": "pipedrive.audit",
      "query": {
        "category": "export",
        "operation": "audit.export.heartbeat"
      },
      "window": "15m",
      "unit": "seconds",
      "warning": 900,
      "critical": 900,
      "drilldown": "docs/INCIDENT_RESPONSE.md",
      "live_status": "not_configured"
    },
    {
      "id": "parse-failures",
      "title": "Parse failures",
      "source": "audit_export_validator",
      "query": {
        "metric": "invalid_marked_record_count",
