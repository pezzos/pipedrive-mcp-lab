{
  "name": "pipedrive-mcp",
  "version": "0.1.6",
  "private": true,
  "license": "MIT",
  "type": "module",
  "bin": {
    "pipedrive-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "INSTALL.md",
    "INSTALL.fr.md",
    "LICENSE",
    "config.example"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "build:plugin": "node scripts/build-plugin.mjs",
    "pack:claude-plugin": "node scripts/pack-claude-plugin.mjs",
    "prepack": "npm run build",
    "test": "node --import tsx --test tests/*.test.ts",
    "check": "npm run build && npm run build:plugin && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "esbuild": "^0.25.12",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
