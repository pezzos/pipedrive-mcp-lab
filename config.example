PIPEDRIVE_COMPANY_DOMAIN=example-company
PIPEDRIVE_API_TOKEN=replace-with-a-sandbox-token
# Optional OAuth alternative for scoped endpoints such as Mailbox.
# PIPEDRIVE_ACCESS_TOKEN=replace-with-oauth-access-token
PIPEDRIVE_ENABLE_WRITES=false
PIPEDRIVE_WRITE_CONFIRMATION=CONFIRM_WRITE
PIPEDRIVE_REQUIRE_WRITE_CONFIRMATION=true
PIPEDRIVE_ALLOW_LAB_WRITE_CONFIRMATION=true
PIPEDRIVE_REQUIRE_LAB_PREFIX=true
PIPEDRIVE_LAB_PREFIX=MCP LAB -
PIPEDRIVE_ALLOW_MOCK_BASE_URL=false
